<Window x:Class="VideoDownloaderUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource AppTitle}" Height="820" Width="1080"
        ResizeMode="NoResize"
        Background="#0F111A" WindowStartupLocation="CenterScreen"
        Icon="logo.png">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryColor"   Color="#BB86FC"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#03DAC6"/>
        <SolidColorBrush x:Key="CardColor"      Color="#1E202E"/>
        <!-- ✅ FIX 1: مورد ديناميكي للون أيقونات التبويبات غير النشطة -->
        <SolidColorBrush x:Key="TabInactiveFg"  Color="#AAAAAA"/>

        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <!-- ✅ FIX 1: استبدال #555 الثابت بمورد ديناميكي -->
            <Setter Property="Foreground"      Value="{DynamicResource TabInactiveFg}"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="20,15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="BtnBg" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border x:Name="ActiveBar" Height="2" VerticalAlignment="Bottom"
                                    Background="{DynamicResource SecondaryColor}" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="active">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="ActiveBar" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBg" Property="Background" Value="#0CFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource SecondaryColor}"/>
            <Setter Property="Foreground"      Value="Black"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.8"/></Trigger>
                <Trigger Property="IsEnabled"   Value="False"><Setter Property="Background" Value="Gray"/></Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StopButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF9800"/><Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.8"/></Trigger>
                <Trigger Property="IsEnabled"   Value="False"><Setter Property="Background" Value="Gray"/></Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ResumeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4CAF50"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.8"/></Trigger>
                <Trigger Property="IsEnabled"   Value="False"><Setter Property="Background" Value="Gray"/></Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F44336"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.8"/></Trigger>
                <Trigger Property="IsEnabled"   Value="False"><Setter Property="Background" Value="Gray"/></Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ConfirmYesStyle" TargetType="Button">
            <Setter Property="Background" Value="#2E7D32"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="170"/><Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <Border.Effect><DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#1B5E20" Opacity="0.5"/></Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#43A047"/></Trigger>
                            <Trigger Property="IsPressed"   Value="True"><Setter TargetName="Bd" Property="Background" Value="#1B5E20"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConfirmNoStyle" TargetType="Button">
            <Setter Property="Background" Value="#C62828"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="140"/><Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <Border.Effect><DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#B71C1C" Opacity="0.5"/></Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#E53935"/></Trigger>
                            <Trigger Property="IsPressed"   Value="True"><Setter TargetName="Bd" Property="Background" Value="#B71C1C"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsSaveStyle" TargetType="Button">
            <Setter Property="Background" Value="#03DAC6"/><Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="Gray"/>
            <Setter Property="FontSize" Value="20"/><Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#2C2E3E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ThemeSwatchStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/><Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="BorderThickness" Value="2"/><Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="BorderBrush" Value="White"/></Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2C2E3E"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="10,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="#2C2E3E" CornerRadius="8" Padding="5">
                            <Grid>
                                <ToggleButton Background="Transparent" BorderThickness="0" Focusable="false"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press"/>
                                <ContentPresenter IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}"
                                                  Margin="3,3,23,3" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                <Path Fill="White" HorizontalAlignment="Right" VerticalAlignment="Center"
                                      Margin="0,0,10,0" Data="M 0 0 L 4 4 L 8 0 Z"/>
                                <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                    <Border Background="#2C2E3E" BorderThickness="1" BorderBrush="#3F4154"
                                            CornerRadius="8" MinWidth="{TemplateBinding ActualWidth}"
                                            MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleCheckStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/><Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Width="44" Height="24" CornerRadius="12" Margin="12,0,0,0" VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#444"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True">
                                                <Setter Property="Background" Value="#03DAC6"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Ellipse Width="18" Height="18" Fill="White" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="Margin" Value="3,0,0,0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True">
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    <Setter Property="Margin" Value="0,0,3,0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsSectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#BB86FC"/><Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/><Setter Property="Margin" Value="0,18,0,8"/>
        </Style>
        <Style x:Key="SettingsFieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/><Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="AboutSectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/><Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#BB86FC"/><Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style x:Key="AboutRowKey" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/><Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Width" Value="115"/><Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <Style x:Key="AboutRowVal" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/><Setter Property="Foreground" Value="#C8C8C8"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TAB BAR -->
        <Border Grid.Row="0" x:Name="TabBarBorder" Background="#08090F" BorderBrush="#15172A" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" Margin="14,0">
                    <Button x:Name="TabDownloaderBtn" Content="{DynamicResource TabDownloader}" Tag="active"
                            Style="{StaticResource TabButtonStyle}" Click="Tab_Downloader_Click"/>
                    <Button x:Name="TabHistoryBtn" Content="{DynamicResource TabHistory}" Tag="inactive"
                            Style="{StaticResource TabButtonStyle}" Click="Tab_History_Click"/>
                    <Button x:Name="TabAboutBtn" Content="{DynamicResource TabAbout}" Tag="inactive"
                            Style="{StaticResource TabButtonStyle}" Click="Tab_About_Click"/>
                </StackPanel>
                <Border HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0"
                        Background="#1A1D2E" CornerRadius="6" Padding="10,4">
                    <TextBlock Text="{DynamicResource VersionLabel}" FontSize="11" FontWeight="Bold" Foreground="#444" FontFamily="Consolas"/>
                </Border>
            </Grid>
        </Border>

        <!-- PAGE 1 — DOWNLOADER -->
        <Grid x:Name="MainContentGrid" Grid.Row="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,30">
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="logo.png" Width="40" Height="40" Margin="0,0,12,0"
                           VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="AppTitleText" Text="{DynamicResource AppTitle}" FontSize="36" FontWeight="ExtraBold"
                                   Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="AppSubtitleText" Text="{DynamicResource AppSubtitle}"
                                   FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </StackPanel>
                <Button x:Name="SettingsButton" Style="{StaticResource IconButtonStyle}"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Content="&#x2699;" ToolTip="Settings" Click="SettingsButton_Click"/>
            </Grid>

            <Border Grid.Row="1" x:Name="InputCard" Background="{StaticResource CardColor}"
                    CornerRadius="15" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <Grid Margin="0,0,0,15">
                        <TextBox x:Name="UrlTextBox" Height="120" Padding="15,10" FontSize="15"
                                 Background="#2C2E3E" Foreground="White" BorderThickness="0"
                                 VerticalContentAlignment="Top" CaretBrush="White"
                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap">
                            <TextBox.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                            </TextBox.Resources>
                        </TextBox>
                        <TextBlock IsHitTestVisible="False" Text="{DynamicResource UrlPlaceholderBatch}"
                                   VerticalAlignment="Top" HorizontalAlignment="Left"
                                   Margin="20,10,0,0" Foreground="Gray" FontSize="15">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=UrlTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock x:Name="QualityLabel" Text="{DynamicResource QualityLabel}" Foreground="Gray" FontSize="12" Margin="5,0,0,5"/>
                            <ComboBox x:Name="QualityComboBox" Height="40" SelectedIndex="0">
                                <ComboBox.Resources>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="#2C2E3E"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Padding"    Value="10"/>
                                    </Style>
                                </ComboBox.Resources>
                                <ComboBoxItem Content="&#x1F3C6; Best Quality" Tag="best"/>
                                <ComboBoxItem Content="── VIDEO ──" Tag="" IsEnabled="False" Foreground="#BB86FC" FontWeight="Bold" FontSize="11"/>
                                <ComboBoxItem Content="4K  — 2160p" Tag="2160"/>
                                <ComboBoxItem Content="2K  — 1440p" Tag="1440"/>
                                <ComboBoxItem Content="FHD — 1080p" Tag="1080"/>
                                <ComboBoxItem Content="HD  —  720p" Tag="720"/>
                                <ComboBoxItem Content="SD  —  480p" Tag="480"/>
                                <ComboBoxItem Content="Low —  360p" Tag="360"/>
                                <ComboBoxItem Content="Min —  240p" Tag="240"/>
                                <ComboBoxItem Content="Min —  144p" Tag="144"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,10,0">
                            <StackPanel Orientation="Horizontal" Margin="5,0,0,5">
                                <TextBlock x:Name="FormatLabel" Text="{DynamicResource FormatLabel}" Foreground="Gray" FontSize="12"/>
                                <TextBlock x:Name="AudioBadge" Text="{DynamicResource AudioBadge}" Foreground="#FF6B6B"
                                           FontSize="11" FontWeight="Bold" Visibility="Collapsed" Margin="5,0,0,0"/>
                            </StackPanel>
                            <ComboBox x:Name="FormatComboBox" Height="40" SelectedIndex="0"
                                      SelectionChanged="FormatComboBox_SelectionChanged">
                                <ComboBox.Resources>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="#2C2E3E"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Padding"    Value="10"/>
                                    </Style>
                                </ComboBox.Resources>
                                <ComboBoxItem Content="── VIDEO ──" Tag="" IsEnabled="False" Foreground="#BB86FC" FontWeight="Bold" FontSize="11"/>
                                <ComboBoxItem Content="MP4"  Tag="mp4"/>
                                <ComboBoxItem Content="WebM" Tag="webm"/>
                                <ComboBoxItem Content="AVI"  Tag="avi"/>
                                <ComboBoxItem Content="WMV"  Tag="wmv"/>
                                <ComboBoxItem Content="── AUDIO ──" Tag="" IsEnabled="False" Foreground="#FF6B6B" FontWeight="Bold" FontSize="11"/>
                                <ComboBoxItem Content="MP3 &#x1F3B5;" Tag="mp3"/>
                                <ComboBoxItem Content="M4A &#x1F3B5;" Tag="m4a"/>
                                <ComboBoxItem Content="WAV &#x1F3B5;" Tag="wav"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <Button x:Name="DownloadButton" Content="{DynamicResource DownloadButtonText}" Width="165" Height="40" Padding="15,10"
                                    Style="{StaticResource ModernButtonStyle}" Click="DownloadButton_Click" Visibility="Visible"/>
                            <Button x:Name="StopButton" Content="{DynamicResource StopButtonText}" Width="110" Height="40" Padding="12,10" Margin="8,0,0,0"
                                    Style="{StaticResource StopButtonStyle}" Click="StopButton_Click" Visibility="Collapsed"/>
                            <Button x:Name="ResumeButton" Content="{DynamicResource ResumeButtonText}" Width="110" Height="40" Padding="12,10" Margin="8,0,0,0"
                                    Style="{StaticResource ResumeButtonStyle}" Click="ResumeButton_Click" Visibility="Collapsed"/>
                            <Button x:Name="CancelButton" Content="{DynamicResource CancelButtonText}" Width="110" Height="40" Padding="12,10" Margin="8,0,0,0"
                                    Style="{StaticResource CancelButtonStyle}" Click="CancelButton_Click" Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" x:Name="ConfirmPanel"
                    Background="#2A1A00" BorderBrush="#FF9800" BorderThickness="1"
                    CornerRadius="12" Padding="18,14" Margin="0,0,0,16" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource ConfirmDuplicateTitle}" FontSize="14" FontWeight="Bold" Foreground="#FF9800"/>
                        <TextBlock x:Name="ConfirmFileNameText" Text="" FontSize="11" Foreground="#AAAAAA" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        <TextBlock Text="{DynamicResource ConfirmDuplicateQuestion}" FontSize="12" Foreground="White" Margin="0,6,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                        <Button x:Name="ConfirmYesButton" Content="{DynamicResource ConfirmYes}"
                                Style="{StaticResource ConfirmYesStyle}" Click="ConfirmYes_Click"/>
                        <Button x:Name="ConfirmNoButton" Content="{DynamicResource ConfirmNo}"
                                Style="{StaticResource ConfirmNoStyle}" Margin="12,0,0,0" Click="ConfirmNo_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="3" x:Name="ProgressLogCard" Background="{StaticResource CardColor}" CornerRadius="15" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0,0,0,15">
                        <Grid Margin="0,0,0,8">
                            <TextBlock x:Name="ProgressLabel" Text="{DynamicResource ProgressLabel}" Foreground="Gray" FontSize="12"/>
                            <TextBlock x:Name="PercentageTextBlock" Text="0%"
                                       Foreground="{StaticResource PrimaryColor}"
                                       HorizontalAlignment="Right" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                        <Grid x:Name="ProgressTrack" Height="14" SizeChanged="ProgressTrack_SizeChanged">
                            <Border x:Name="ProgressTrackBg" CornerRadius="7" Background="#1C1D2B"/>
                            <Border x:Name="ProgressFill" HorizontalAlignment="Left" CornerRadius="7" Width="0" ClipToBounds="True">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#1A6B00" Offset="0.0"/>
                                        <GradientStop Color="#39FF14" Offset="0.5"/>
                                        <GradientStop Color="#1DB300" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Canvas IsHitTestVisible="False" ClipToBounds="True">
                                    <Rectangle x:Name="ShimmerRect" Width="160" Height="40" Canvas.Left="-160" Canvas.Top="-13">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#00FFFFFF" Offset="0.0"/>
                                                <GradientStop Color="#00FFFFFF" Offset="0.2"/>
                                                <GradientStop Color="#60FFFFFF" Offset="0.5"/>
                                                <GradientStop Color="#00FFFFFF" Offset="0.8"/>
                                                <GradientStop Color="#00FFFFFF" Offset="1.0"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                        <Rectangle.Triggers>
                                            <EventTrigger RoutedEvent="Rectangle.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetName="ShimmerRect"
                                                            Storyboard.TargetProperty="(Canvas.Left)"
                                                            From="-160" To="900" Duration="0:0:1.8" RepeatBehavior="Forever"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Rectangle.Triggers>
                                    </Rectangle>
                                    <Rectangle Canvas.Left="0" Canvas.Top="0" Width="1200" Height="5">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#45FFFFFF" Offset="0"/>
                                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                </Canvas>
                            </Border>
                        </Grid>
                    </StackPanel>
                    <Grid Grid.Row="1">
                        <ScrollViewer x:Name="LogScrollViewer" Background="#141622" BorderBrush="#2C2E3E" BorderThickness="1">
                            <TextBlock x:Name="LogTextBlock" TextWrapping="Wrap"
                                       Foreground="{StaticResource SecondaryColor}"
                                       Padding="15" FontFamily="Consolas" FontSize="12"/>
                        </ScrollViewer>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,10">
                            <Button x:Name="OpenFolderBtn" Content="{DynamicResource OpenFolderButtonText}" Click="OpenFolder_Click"
                                    Width="120" Height="28" Cursor="Hand" Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#22FFFFFF"/><Setter Property="Foreground" Value="#888888"/>
                                        <Setter Property="FontSize" Value="11"/><Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="BorderThickness" Value="1"/><Setter Property="BorderBrush" Value="#33FFFFFF"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#44BB86FC"/>
                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#88BB86FC"/>
                                                            <Setter Property="Foreground" Value="#BB86FC"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#88BB86FC"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button x:Name="ClearLogButton" Content="{DynamicResource ClearLogButtonText}" Click="ClearLog_Click"
                                    Width="78" Height="28" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#22FFFFFF"/><Setter Property="Foreground" Value="#888888"/>
                                        <Setter Property="FontSize" Value="11"/><Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="BorderThickness" Value="1"/><Setter Property="BorderBrush" Value="#33FFFFFF"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#44F44336"/>
                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#88F44336"/>
                                                            <Setter Property="Foreground" Value="#F44336"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#88F44336"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Opacity" Value="0.25"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <StatusBar Grid.Row="4" Background="Transparent" Margin="0,15,0,0">
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8"
                                 Fill="{StaticResource SecondaryColor}" Margin="0,0,8,0"/>
                        <TextBlock x:Name="StatusTextBlock" Text="{DynamicResource StatusReady}" Foreground="Gray" FontSize="12"/>
                    </StackPanel>
                </StatusBarItem>
                <StatusBarItem HorizontalAlignment="Right">
                    <TextBlock x:Name="DownloadPathLabel" Text="" Foreground="#444" FontSize="11"
                               FontFamily="Consolas" ToolTip="Current download directory"/>
                </StatusBarItem>
            </StatusBar>
        </Grid>

        <!-- PAGE 2 — HISTORY -->
        <Grid x:Name="HistoryContentGrid" Grid.Row="1" Visibility="Collapsed" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,20">
                <TextBlock x:Name="HistoryTitleText" Text="{DynamicResource HistoryTitle}" FontSize="28" FontWeight="ExtraBold" Foreground="#BB86FC"/>
                <TextBlock x:Name="HistorySubtitleText" Text="{DynamicResource HistorySubtitle}" FontSize="13" Foreground="Gray" Margin="0,4,0,0"/>
            </StackPanel>

            <Border Grid.Row="1" x:Name="HistoryCard" Background="{StaticResource CardColor}" CornerRadius="15" Padding="10">
                <Grid>
                    <ListView x:Name="HistoryListView" Background="Transparent" BorderThickness="0" Foreground="White"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.Resources>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="#BB86FC"/>
                                <Setter Property="FontWeight" Value="Bold"/><Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/><Setter Property="BorderBrush" Value="#2A2D45"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            </Style>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#1A1C2E"/><Setter Property="Padding" Value="0,4"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                                <GridViewRowPresenter VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#0CFFFFFF"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.Resources>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="{DynamicResource ColDate}" Width="150" DisplayMemberBinding="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"/>
                                <GridViewColumn Header="{DynamicResource ColUrl}" Width="400">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Url}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Url}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{DynamicResource ColFormat}" Width="80" DisplayMemberBinding="{Binding Format}"/>
                                <GridViewColumn Header="{DynamicResource ColQuality}" Width="100" DisplayMemberBinding="{Binding Quality}"/>
                                <GridViewColumn Header="{DynamicResource ColStatus}" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#1C0808"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                                                <Setter Property="Background" Value="#0B1C0B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontWeight="Bold" FontSize="10">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{DynamicResource StatusFail}"/>
                                                            <Setter Property="Foreground" Value="#F44336"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                                                    <Setter Property="Text" Value="{DynamicResource StatusOk}"/>
                                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <StackPanel x:Name="NoHistoryPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                        <TextBlock Text="&#x1F4DC;" FontSize="48" HorizontalAlignment="Center" Opacity="0.2"/>
                        <TextBlock Text="{DynamicResource NoHistoryMsg}" Foreground="Gray" FontSize="14" Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Button Grid.Row="2" x:Name="ClearHistoryBtn" Content="{DynamicResource ClearHistoryBtn}"
                    HorizontalAlignment="Right" Margin="0,20,0,0" Padding="20,10"
                    Style="{StaticResource ModernButtonStyle}" Background="#33F44336" Foreground="#F44336"
                    Click="ClearHistory_Click">
                <Button.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                </Button.Resources>
            </Button>
        </Grid>

        <!-- PAGE 3 — ABOUT -->
        <Grid x:Name="AboutContentGrid" Grid.Row="1" Visibility="Collapsed" Margin="30,10,30,30">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- App Identity Banner -->
                    <Border x:Name="AboutIdentityCard" CornerRadius="16" Padding="28,24" Margin="0,0,0,18" ClipToBounds="True">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#12142A" Offset="0.0"/>
                                <GradientStop Color="#1A0E2E" Offset="0.5"/>
                                <GradientStop Color="#0A1F22" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Color="#000000" Opacity="0.5"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Image Source="logo.png" Width="48" Height="48" Margin="0,0,14,0"
                                           VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text="{DynamicResource AppTitle}"
                                               FontSize="26" FontWeight="ExtraBold"
                                               Foreground="#BB86FC" VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Text="{DynamicResource AppSubtitle}"
                                           FontSize="13" Foreground="#555" Margin="0,0,0,16"/>

                                <TextBlock x:Name="AboutDesc1" Text="{DynamicResource AboutDescLine1}" FontSize="12" Foreground="#666" Margin="0,0,0,2" TextWrapping="Wrap"/>
                                <TextBlock x:Name="AboutDesc2" Text="{DynamicResource AboutDescLine2}" FontSize="12" Foreground="#666" Margin="0,0,0,2" TextWrapping="Wrap"/>
                                <TextBlock x:Name="AboutDesc3" Text="{DynamicResource AboutDescLine3}" FontSize="12" Foreground="#666" Margin="0,0,0,16" TextWrapping="Wrap"/>

                                <Border Height="1" Background="#1E2040" Margin="0,0,0,14"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="{DynamicResource DesignedBy}" Foreground="#666" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text="Hamza Saadi" Foreground="#BB86FC" FontSize="12"
                                               FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                    <TextBlock Text="·" Foreground="#333" FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                    <TextBlock Text="{DynamicResource LastUpdated}" Foreground="#666" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text="12/03/2026" Foreground="#03DAC6" FontSize="12"
                                               FontFamily="Consolas" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Website:  " Foreground="#666" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock FontSize="12" VerticalAlignment="Center">
                                        <Hyperlink NavigateUri="https://eagleshadow.technology"
                                                   RequestNavigate="Hyperlink_RequestNavigate">
                                            <Hyperlink.Style>
                                                <Style TargetType="Hyperlink">
                                                    <Setter Property="Foreground" Value="#03DAC6"/>
                                                    <Setter Property="TextDecorations" Value="None"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Foreground" Value="#BB86FC"/>
                                                            <Setter Property="TextDecorations" Value="Underline"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Hyperlink.Style>
                                            https://eagleshadow.technology
                                        </Hyperlink>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>

                            <!-- Right: Version orb -->
                            <Border Grid.Column="1" Width="88" Height="88" CornerRadius="44"
                                    VerticalAlignment="Center" Margin="20,0,0,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#7C4DFF" Offset="0.0"/>
                                        <GradientStop Color="#03DAC6" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#5500FF" Opacity="0.5"/>
                                </Border.Effect>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="v 2.1" FontSize="17" FontWeight="ExtraBold"
                                               Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="P R O" FontSize="9" FontWeight="Bold"
                                               Foreground="#AAFFFFFF" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Logo (LEFT) + System Info (RIGHT) -->
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: Logo Card -->
                        <Border Grid.Column="0" x:Name="AboutLogoCard"
                                Background="{StaticResource CardColor}"
                                CornerRadius="14" ClipToBounds="True">
                            <Grid>
                                <Border CornerRadius="14" Opacity="0.12">
                                    <Border.Background>
                                        <RadialGradientBrush Center="0.5,0.5" RadiusX="0.65" RadiusY="0.65">
                                            <GradientStop Color="#BB86FC" Offset="0.0"/>
                                            <GradientStop Color="Transparent" Offset="1.0"/>
                                        </RadialGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Image Source="developer.png" Stretch="Uniform"
                                       MaxWidth="280" MaxHeight="280"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Margin="36" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Grid>
                        </Border>

                        <!-- RIGHT: System Info Card -->
                        <Border Grid.Column="2" x:Name="AboutSysCard"
                                Background="{StaticResource CardColor}" CornerRadius="14" Padding="24">
                            <StackPanel>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource AboutSectionLabel}" Text="{DynamicResource SystemInfoLabel}" Margin="0"/>
                                    <Button Grid.Column="1" x:Name="RefreshSysInfoBtn" Content="{DynamicResource RefreshButtonText}"
                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                            FontSize="11" FontWeight="SemiBold" Foreground="#444"
                                            Background="Transparent" BorderThickness="1" BorderBrush="#2A2D45"
                                            Cursor="Hand" Padding="8,3" Click="RefreshSysInfo_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#03DAC6"/>
                                                        <Setter Property="Foreground" Value="#03DAC6"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource AboutRowKey}" Text="{DynamicResource OsLabel}"/>
                                    <TextBlock x:Name="SysOsText" Style="{StaticResource AboutRowVal}" Grid.Column="1" Text="Detecting..."/>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource AboutRowKey}" Text="{DynamicResource DotnetLabel}"/>
                                    <TextBlock x:Name="SysDotnetText" Style="{StaticResource AboutRowVal}" Grid.Column="1" Text="Detecting..."/>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource AboutRowKey}" Text="{DynamicResource ArchLabel}"/>
                                    <TextBlock x:Name="SysArchText" Style="{StaticResource AboutRowVal}" Grid.Column="1" Text="Detecting..."/>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource AboutRowKey}" Text="{DynamicResource CpuLabel}"/>
                                    <TextBlock x:Name="SysCpuText" Style="{StaticResource AboutRowVal}" Grid.Column="1" Text="Detecting..."/>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource AboutRowKey}" Text="{DynamicResource SettingsPathLabel}"/>
                                    <TextBlock x:Name="SysAppDataText" Style="{StaticResource AboutRowVal}" Grid.Column="1" Text="Detecting..." TextWrapping="Wrap"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource AboutRowKey}" Text="{DynamicResource ExeLocationLabel}"/>
                                    <TextBlock x:Name="SysExePathText" Style="{StaticResource AboutRowVal}" Grid.Column="1" Text="Detecting..." TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- CHANGELOG -->
                    <Border x:Name="AboutChangelogCard" Background="{StaticResource CardColor}"
                            CornerRadius="14" Padding="0" Margin="0,0,0,18" ClipToBounds="True">
                        <StackPanel>

                            <!-- Header bar -->
                            <Border CornerRadius="14,14,0,0" Padding="24,18,24,16">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#18142E" Offset="0"/>
                                        <GradientStop Color="#0F1520" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Background="#2A1A4A" CornerRadius="5" Padding="8,4" Margin="0,0,12,0">
                                            <TextBlock Text="&#x1F4CB;" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel>
                                            <TextBlock Text="{DynamicResource ChangelogLabel}" FontFamily="Consolas" FontSize="10"
                                                       FontWeight="Bold" Foreground="#BB86FC" Margin="0,0,0,2"/>
                                            <TextBlock Text="{DynamicResource ChangelogSubtitle}"
                                                       FontSize="12" Foreground="#444"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#1A0D2E" CornerRadius="20"
                                            Padding="12,5" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="3" FontFamily="Consolas" FontSize="14"
                                                       FontWeight="Bold" Foreground="#BB86FC" VerticalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource ReleasesCount}" FontSize="11" Foreground="#555"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Height="1" Background="#14162A"/>

                            <!-- v 2.1 -->
                            <Border Padding="24,22,24,20">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#130E22" Offset="0"/>
                                        <GradientStop Color="#0F111A" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="64"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Background="#1A0D2E" CornerRadius="8" Padding="0,6"
                                            HorizontalAlignment="Center" Width="52" VerticalAlignment="Top" Margin="0,2,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="#7C4DFF" Opacity="0.45"/>
                                        </Border.Effect>
                                        <TextBlock Text="v 2.1" FontFamily="Consolas" FontSize="12"
                                                   FontWeight="Bold" Foreground="#BB86FC" HorizontalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1">
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                    <TextBlock Text="{DynamicResource CurrentRelease}" FontSize="15" FontWeight="Bold"
                                                               Foreground="White" VerticalAlignment="Center"/>
                                                    <Border Background="#1A0D2E" CornerRadius="10" Padding="8,3"
                                                            Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Ellipse Width="5" Height="5" Fill="#BB86FC"
                                                                     VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                            <TextBlock Text="{DynamicResource LatestBadge}" FontFamily="Consolas"
                                                                       FontSize="9" FontWeight="Bold" Foreground="#BB86FC"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{DynamicResource v2_1_Date}" FontFamily="Consolas"
                                                           FontSize="10" Foreground="#444"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="#12101C" CornerRadius="8"
                                                    Padding="10,5" VerticalAlignment="Top">
                                                <TextBlock Text="{DynamicResource v2_1_ChangesCount}" FontFamily="Consolas" FontSize="11" Foreground="#555"/>
                                            </Border>
                                        </Grid>

                                        <StackPanel>
                                            <Border Margin="0,0,0,6" CornerRadius="8" Padding="12,10"
                                                    Background="#0D0B18" BorderThickness="1" BorderBrush="#1E1830">
