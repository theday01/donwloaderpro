<Window x:Class="VideoDownloaderUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Pro Video Downloader - by EagleShadow" Height="820" Width="1080"
        Background="#0F111A" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryColor"   Color="#BB86FC"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#03DAC6"/>
        <SolidColorBrush x:Key="CardColor"      Color="#1E202E"/>

        <!-- ── Tab Button ── -->
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#555"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="20,15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="BtnBg" Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border x:Name="ActiveBar" Height="2" VerticalAlignment="Bottom"
                                    Background="{DynamicResource SecondaryColor}" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Value="active">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="ActiveBar" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBg" Property="Background" Value="#0CFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Modern Button ── -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource SecondaryColor}"/>
            <Setter Property="Foreground"      Value="Black"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.8"/></Trigger>
                <Trigger Property="IsEnabled"   Value="False"><Setter Property="Background" Value="Gray"/></Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Stop Button ── -->
        <Style x:Key="StopButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF9800"/><Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.8"/></Trigger>
                <Trigger Property="IsEnabled"   Value="False"><Setter Property="Background" Value="Gray"/></Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Resume Button ── -->
        <Style x:Key="ResumeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4CAF50"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.8"/></Trigger>
                <Trigger Property="IsEnabled"   Value="False"><Setter Property="Background" Value="Gray"/></Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Cancel Button ── -->
        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F44336"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.8"/></Trigger>
                <Trigger Property="IsEnabled"   Value="False"><Setter Property="Background" Value="Gray"/></Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Confirm Yes ── -->
        <Style x:Key="ConfirmYesStyle" TargetType="Button">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="MinWidth"   Value="170"/>
            <Setter Property="Height"     Value="42"/>
            <Setter Property="Padding"    Value="18,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2"
                                                  Color="#1B5E20" Opacity="0.5"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#43A047"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1B5E20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Confirm No ── -->
        <Style x:Key="ConfirmNoStyle" TargetType="Button">
            <Setter Property="Background" Value="#C62828"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="MinWidth"   Value="140"/>
            <Setter Property="Height"     Value="42"/>
            <Setter Property="Padding"    Value="18,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2"
                                                  Color="#B71C1C" Opacity="0.5"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E53935"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#B71C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Settings Save Button ── -->
        <Style x:Key="SettingsSaveStyle" TargetType="Button">
            <Setter Property="Background" Value="#03DAC6"/><Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Icon Button (gear/close) ── -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="FontSize"   Value="20"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#2C2E3E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Theme Swatch Button ── -->
        <Style x:Key="ThemeSwatchStyle" TargetType="Button">
            <Setter Property="Width"  Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── ComboBox ── -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"               Value="#2C2E3E"/>
            <Setter Property="Foreground"               Value="White"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="Padding"                  Value="10,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="#2C2E3E" CornerRadius="8" Padding="5">
                            <Grid>
                                <ToggleButton Background="Transparent" BorderThickness="0" Focusable="false"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                          RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press"/>
                                <ContentPresenter IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  Margin="3,3,23,3" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                <Path Fill="White" HorizontalAlignment="Right" VerticalAlignment="Center"
                                      Margin="0,0,10,0" Data="M 0 0 L 4 4 L 8 0 Z"/>
                                <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                    <Border Background="#2C2E3E" BorderThickness="1" BorderBrush="#3F4154"
                                            CornerRadius="8" MinWidth="{TemplateBinding ActualWidth}"
                                            MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Settings Toggle CheckBox ── -->
        <Style x:Key="ToggleCheckStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Width="44" Height="24" CornerRadius="12"
                                    Margin="12,0,0,0" VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#444"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True">
                                                <Setter Property="Background" Value="#03DAC6"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Ellipse Width="18" Height="18" Fill="White" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="Margin" Value="3,0,0,0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True">
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                    <Setter Property="Margin" Value="0,0,3,0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Settings Section TextBlock label ── -->
        <Style x:Key="SettingsSectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#BB86FC"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,18,0,8"/>
            <Setter Property="Text"        Value="SECTION"/>
        </Style>

        <!-- ── Settings field label ── -->
        <Style x:Key="SettingsFieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>

        <!-- ── About section label ── -->
        <Style x:Key="AboutSectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#BB86FC"/>
            <Setter Property="Margin"     Value="0,0,0,14"/>
        </Style>

        <!-- ── About info row key ── -->
        <Style x:Key="AboutRowKey" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Width"      Value="115"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <!-- ── About info row value ── -->
        <Style x:Key="AboutRowVal" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Foreground"   Value="#C8C8C8"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

    </Window.Resources>

    <!-- Root Grid: tab bar + content + settings overlay -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0  Tab navigation bar -->
            <RowDefinition Height="*"/>     <!-- 1  Page content       -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════
             TAB NAVIGATION BAR
             ════════════════════════════════════════════════ -->
        <Border Grid.Row="0" x:Name="TabBarBorder"
                Background="#08090F" BorderBrush="#15172A" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" Margin="14,0">
                    <Button x:Name="TabDownloaderBtn"
                            Content="⬇  Downloader"
                            Tag="active"
                            Style="{StaticResource TabButtonStyle}"
                            Click="Tab_Downloader_Click"/>
                    <Button x:Name="TabAboutBtn"
                            Content="ℹ  About &amp; System"
                            Tag="inactive"
                            Style="{StaticResource TabButtonStyle}"
                            Click="Tab_About_Click"/>
                </StackPanel>
                <!-- App version badge (top-right) -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="0,0,20,0" Background="#1A1D2E" CornerRadius="6" Padding="10,4">
                    <TextBlock Text="v2.1 PRO" FontSize="11" FontWeight="Bold"
                               Foreground="#444" FontFamily="Consolas"/>
                </Border>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════
             PAGE 1 — DOWNLOADER (main content)
             ════════════════════════════════════════════════ -->
        <Grid x:Name="MainContentGrid" Grid.Row="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 0 Header        -->
                <RowDefinition Height="Auto"/>  <!-- 1 Input card    -->
                <RowDefinition Height="Auto"/>  <!-- 2 Confirm panel -->
                <RowDefinition Height="*"/>     <!-- 3 Progress/Log  -->
                <RowDefinition Height="Auto"/>  <!-- 4 Footer        -->
            </Grid.RowDefinitions>

            <!-- ── Header ── -->
            <Grid Margin="0,0,0,30">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="AppTitleText" Text="Video Downloader Pro" FontSize="36" FontWeight="ExtraBold"
                               Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="AppSubtitleText" Text="Fast &amp; High Quality Downloads — Video &amp; Audio" FontSize="14"
                               Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
                <!-- Settings Gear Button -->
                <Button x:Name="SettingsButton" Style="{StaticResource IconButtonStyle}"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Content="⚙" ToolTip="Settings" Click="SettingsButton_Click"/>
            </Grid>

            <!-- ── Input card ── -->
            <Border Grid.Row="1" x:Name="InputCard" Background="{StaticResource CardColor}"
                    CornerRadius="15" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <Grid Margin="0,0,0,15">
                        <TextBox x:Name="UrlTextBox" Height="45" Padding="15,5" FontSize="15"
                                 Background="#2C2E3E" Foreground="White" BorderThickness="0"
                                 VerticalContentAlignment="Center" CaretBrush="White">
                            <TextBox.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                            </TextBox.Resources>
                        </TextBox>
                        <TextBlock IsHitTestVisible="False" Text="Enter the video link here ..."
                                   VerticalAlignment="Center" HorizontalAlignment="Left"
                                   Margin="20,0,0,0" Foreground="Gray" FontSize="15">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=UrlTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Quality -->
                        <StackPanel Margin="0,0,10,0">
                            <TextBlock x:Name="QualityLabel" Text="Quality" Foreground="Gray" FontSize="12" Margin="5,0,0,5"/>
                            <ComboBox x:Name="QualityComboBox" Height="40" SelectedIndex="0">
                                <ComboBox.Resources>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="#2C2E3E"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Padding"    Value="10"/>
                                    </Style>
                                </ComboBox.Resources>
                                <ComboBoxItem Content="🏆 Best Quality" Tag="best"/>
                                <ComboBoxItem Content="── VIDEO ──" Tag="" IsEnabled="False"
                                              Foreground="#BB86FC" FontWeight="Bold" FontSize="11"/>
                                <ComboBoxItem Content="4K  — 2160p" Tag="2160"/>
                                <ComboBoxItem Content="2K  — 1440p" Tag="1440"/>
                                <ComboBoxItem Content="FHD — 1080p" Tag="1080"/>
                                <ComboBoxItem Content="HD  —  720p" Tag="720"/>
                                <ComboBoxItem Content="SD  —  480p" Tag="480"/>
                                <ComboBoxItem Content="Low —  360p" Tag="360"/>
                                <ComboBoxItem Content="Min —  240p" Tag="240"/>
                                <ComboBoxItem Content="Min —  144p" Tag="144"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Format -->
                        <StackPanel Grid.Column="1" Margin="10,0,10,0">
                            <StackPanel Orientation="Horizontal" Margin="5,0,0,5">
                                <TextBlock x:Name="FormatLabel" Text="Format" Foreground="Gray" FontSize="12"/>
                                <TextBlock x:Name="AudioBadge" Text=" 🎵 AUDIO" Foreground="#FF6B6B"
                                           FontSize="11" FontWeight="Bold" Visibility="Collapsed"/>
                            </StackPanel>
                            <ComboBox x:Name="FormatComboBox" Height="40" SelectedIndex="0"
                                      SelectionChanged="FormatComboBox_SelectionChanged">
                                <ComboBox.Resources>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="#2C2E3E"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Padding"    Value="10"/>
                                    </Style>
                                </ComboBox.Resources>
                                <ComboBoxItem Content="── VIDEO ──" Tag="" IsEnabled="False"
                                              Foreground="#BB86FC" FontWeight="Bold" FontSize="11"/>
                                <ComboBoxItem Content="MP4"  Tag="mp4"/>
                                <ComboBoxItem Content="WebM" Tag="webm"/>
                                <ComboBoxItem Content="AVI"  Tag="avi"/>
                                <ComboBoxItem Content="WMV"  Tag="wmv"/>
                                <ComboBoxItem Content="── AUDIO ──" Tag="" IsEnabled="False"
                                              Foreground="#FF6B6B" FontWeight="Bold" FontSize="11"/>
                                <ComboBoxItem Content="MP3 🎵" Tag="mp3"/>
                                <ComboBoxItem Content="M4A 🎵" Tag="m4a"/>
                                <ComboBoxItem Content="WAV 🎵" Tag="wav"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Buttons -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <Button x:Name="DownloadButton"
                                    Content="⬇ DOWNLOAD NOW" Width="165" Height="40" Padding="15,10"
                                    Style="{StaticResource ModernButtonStyle}"
                                    Click="DownloadButton_Click" Visibility="Visible"/>
                            <Button x:Name="StopButton"
                                    Content="⏸ STOP" Width="110" Height="40" Padding="12,10" Margin="8,0,0,0"
                                    Style="{StaticResource StopButtonStyle}"
                                    Click="StopButton_Click" Visibility="Collapsed"/>
                            <Button x:Name="ResumeButton"
                                    Content="▶ RESUME" Width="110" Height="40" Padding="12,10" Margin="8,0,0,0"
                                    Style="{StaticResource ResumeButtonStyle}"
                                    Click="ResumeButton_Click" Visibility="Collapsed"/>
                            <Button x:Name="CancelButton"
                                    Content="✖ CANCEL" Width="110" Height="40" Padding="12,10" Margin="8,0,0,0"
                                    Style="{StaticResource CancelButtonStyle}"
                                    Click="CancelButton_Click" Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── Duplicate confirm panel ── -->
            <Border Grid.Row="2" x:Name="ConfirmPanel"
                    Background="#2A1A00" BorderBrush="#FF9800" BorderThickness="1"
                    CornerRadius="12" Padding="18,14" Margin="0,0,0,16"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="⚠  This file was already downloaded!" FontSize="14"
                                   FontWeight="Bold" Foreground="#FF9800"/>
                        <TextBlock x:Name="ConfirmFileNameText" Text="" FontSize="11"
                                   Foreground="#AAAAAA" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        <TextBlock Text="Do you want to re-download it with the new quality/format?"
                                   FontSize="12" Foreground="White" Margin="0,6,0,0"/>
                    </StackPanel>
