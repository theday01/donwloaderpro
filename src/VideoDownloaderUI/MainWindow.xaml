<Window x:Class="VideoDownloaderUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Pro Video Downloader - by EagleShadow" Height="660" Width="900"
        Background="#0F111A" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryColor"   Color="#BB86FC"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#03DAC6"/>
        <SolidColorBrush x:Key="CardColor"      Color="#1E202E"/>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource SecondaryColor}"/>
            <Setter Property="Foreground"      Value="Black"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.8"/></Trigger>
                <Trigger Property="IsEnabled"   Value="False"><Setter Property="Background" Value="Gray"/></Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StopButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF9800"/><Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.8"/></Trigger>
                <Trigger Property="IsEnabled"   Value="False"><Setter Property="Background" Value="Gray"/></Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ResumeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4CAF50"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.8"/></Trigger>
                <Trigger Property="IsEnabled"   Value="False"><Setter Property="Background" Value="Gray"/></Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F44336"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.8"/></Trigger>
                <Trigger Property="IsEnabled"   Value="False"><Setter Property="Background" Value="Gray"/></Trigger>
            </Style.Triggers>
        </Style>

        <!-- Confirm panel button: Yes (green) -->
        <Style x:Key="ConfirmYesStyle" TargetType="Button">
            <Setter Property="Background" Value="#4CAF50"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.8"/></Trigger>
            </Style.Triggers>
        </Style>

        <!-- Confirm panel button: No (red) -->
        <Style x:Key="ConfirmNoStyle" TargetType="Button">
            <Setter Property="Background" Value="#F44336"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.8"/></Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background"               Value="#2C2E3E"/>
            <Setter Property="Foreground"               Value="White"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="Padding"                  Value="10,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="#2C2E3E" CornerRadius="8" Padding="5">
                            <Grid>
                                <ToggleButton Background="Transparent" BorderThickness="0" Focusable="false"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                          RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press"/>
                                <ContentPresenter IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  Margin="3,3,23,3" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                <Path Fill="White" HorizontalAlignment="Right" VerticalAlignment="Center"
                                      Margin="0,0,10,0" Data="M 0 0 L 4 4 L 8 0 Z"/>
                                <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                    <Border Background="#2C2E3E" BorderThickness="1" BorderBrush="#3F4154"
                                            CornerRadius="8" MinWidth="{TemplateBinding ActualWidth}"
                                            MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0 Header        -->
            <RowDefinition Height="Auto"/>  <!-- 1 Input card    -->
            <RowDefinition Height="Auto"/>  <!-- 2 Confirm panel -->
            <RowDefinition Height="*"/>     <!-- 3 Progress/Log  -->
            <RowDefinition Height="Auto"/>  <!-- 4 Footer        -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <StackPanel Margin="0,0,0,30">
            <TextBlock Text="Video Downloader Pro" FontSize="36" FontWeight="ExtraBold"
                       Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center"/>
            <TextBlock Text="Fast &amp; High Quality Downloads — Video &amp; Audio" FontSize="14"
                       Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- ── Input card ── -->
        <Border Grid.Row="1" Background="{StaticResource CardColor}"
                CornerRadius="15" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <Grid Margin="0,0,0,15">
                    <TextBox x:Name="UrlTextBox" Height="45" Padding="15,5" FontSize="15"
                             Background="#2C2E3E" Foreground="White" BorderThickness="0"
                             VerticalContentAlignment="Center" CaretBrush="White">
                        <TextBox.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="8"/></Style>
                        </TextBox.Resources>
                    </TextBox>
                    <TextBlock IsHitTestVisible="False" Text="Enter the video link here ..."
                               VerticalAlignment="Center" HorizontalAlignment="Left"
                               Margin="20,0,0,0" Foreground="Gray" FontSize="15">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=UrlTextBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Quality -->
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Quality" Foreground="Gray" FontSize="12" Margin="5,0,0,5"/>
                        <ComboBox x:Name="QualityComboBox" Height="40" SelectedIndex="0">
                            <ComboBox.Resources>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Background" Value="#2C2E3E"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Padding"    Value="10"/>
                                </Style>
                            </ComboBox.Resources>
                            <ComboBoxItem Content="🏆 Best Quality" Tag="best"/>
                            <ComboBoxItem Content="── VIDEO ──" Tag="" IsEnabled="False"
                                          Foreground="#BB86FC" FontWeight="Bold" FontSize="11"/>
                            <ComboBoxItem Content="4K  — 2160p" Tag="2160"/>
                            <ComboBoxItem Content="2K  — 1440p" Tag="1440"/>
                            <ComboBoxItem Content="FHD — 1080p" Tag="1080"/>
                            <ComboBoxItem Content="HD  —  720p" Tag="720"/>
                            <ComboBoxItem Content="SD  —  480p" Tag="480"/>
                            <ComboBoxItem Content="Low —  360p" Tag="360"/>
                            <ComboBoxItem Content="Min —  240p" Tag="240"/>
                            <ComboBoxItem Content="Min —  144p" Tag="144"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Format -->
                    <StackPanel Grid.Column="1" Margin="10,0,10,0">
                        <StackPanel Orientation="Horizontal" Margin="5,0,0,5">
                            <TextBlock Text="Format" Foreground="Gray" FontSize="12"/>
                            <TextBlock x:Name="AudioBadge" Text=" 🎵 AUDIO" Foreground="#FF6B6B"
                                       FontSize="11" FontWeight="Bold" Visibility="Collapsed"/>
                        </StackPanel>
                        <ComboBox x:Name="FormatComboBox" Height="40" SelectedIndex="0"
                                  SelectionChanged="FormatComboBox_SelectionChanged">
                            <ComboBox.Resources>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Background" Value="#2C2E3E"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Padding"    Value="10"/>
                                </Style>
                            </ComboBox.Resources>
                            <ComboBoxItem Content="── VIDEO ──" Tag="" IsEnabled="False"
                                          Foreground="#BB86FC" FontWeight="Bold" FontSize="11"/>
                            <ComboBoxItem Content="MP4"  Tag="mp4"/>
                            <ComboBoxItem Content="WebM" Tag="webm"/>
                            <ComboBoxItem Content="AVI"  Tag="avi"/>
                            <ComboBoxItem Content="WMV"  Tag="wmv"/>
                            <ComboBoxItem Content="── AUDIO ──" Tag="" IsEnabled="False"
                                          Foreground="#FF6B6B" FontWeight="Bold" FontSize="11"/>
                            <ComboBoxItem Content="MP3 🎵" Tag="mp3"/>
                            <ComboBoxItem Content="M4A 🎵" Tag="m4a"/>
                            <ComboBoxItem Content="WAV 🎵" Tag="wav"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button x:Name="DownloadButton"
                                Content="⬇ DOWNLOAD NOW" Width="165" Height="40" Padding="15,10"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="DownloadButton_Click" Visibility="Visible"/>
                        <Button x:Name="StopButton"
                                Content="⏸ STOP" Width="110" Height="40" Padding="12,10" Margin="8,0,0,0"
                                Style="{StaticResource StopButtonStyle}"
                                Click="StopButton_Click" Visibility="Collapsed"/>
                        <Button x:Name="ResumeButton"
                                Content="▶ RESUME" Width="110" Height="40" Padding="12,10" Margin="8,0,0,0"
                                Style="{StaticResource ResumeButtonStyle}"
                                Click="ResumeButton_Click" Visibility="Collapsed"/>
                        <Button x:Name="CancelButton"
                                Content="✖ CANCEL" Width="110" Height="40" Padding="12,10" Margin="8,0,0,0"
                                Style="{StaticResource CancelButtonStyle}"
                                Click="CancelButton_Click" Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── Duplicate confirm panel (hidden until needed) ── -->
        <Border Grid.Row="2" x:Name="ConfirmPanel"
                Background="#2A1A00" BorderBrush="#FF9800" BorderThickness="1"
                CornerRadius="12" Padding="18,14" Margin="0,0,0,16"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="⚠  This file was already downloaded!" FontSize="14"
                               FontWeight="Bold" Foreground="#FF9800"/>
                    <TextBlock x:Name="ConfirmFileNameText" Text="" FontSize="11"
                               Foreground="#AAAAAA" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    <TextBlock Text="Do you want to re-download it with the new quality/format?"
                               FontSize="12" Foreground="White" Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Button x:Name="ConfirmYesButton"
                            Content="✔ Yes, Re-download" Width="150" Height="38" Padding="12,8"
                            Style="{StaticResource ConfirmYesStyle}"
                            Click="ConfirmYes_Click"/>
                    <Button x:Name="ConfirmNoButton"
                            Content="✖ No, Cancel" Width="120" Height="38" Padding="12,8" Margin="10,0,0,0"
                            Style="{StaticResource ConfirmNoStyle}"
                            Click="ConfirmNo_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Progress + Log card ── -->
        <Border Grid.Row="3" Background="{StaticResource CardColor}" CornerRadius="15" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,15">
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Download Progress" Foreground="Gray" FontSize="12"/>
                        <TextBlock x:Name="PercentageTextBlock" Text="0%"
                                   Foreground="{StaticResource PrimaryColor}"
                                   HorizontalAlignment="Right" FontSize="12" FontWeight="Bold"/>
                    </Grid>

                    <Grid x:Name="ProgressTrack" Height="14" SizeChanged="ProgressTrack_SizeChanged">
                        <Border CornerRadius="7" Background="#1C1D2B"/>
                        <Border x:Name="ProgressFill" HorizontalAlignment="Left" CornerRadius="7"
                                Width="0" ClipToBounds="True">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1A6B00" Offset="0.0"/>
                                    <GradientStop Color="#39FF14" Offset="0.5"/>
                                    <GradientStop Color="#1DB300" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Canvas IsHitTestVisible="False" ClipToBounds="True">
                                <Rectangle x:Name="ShimmerRect" Width="160" Height="40"
                                           Canvas.Left="-160" Canvas.Top="-13">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00FFFFFF" Offset="0.0"/>
                                            <GradientStop Color="#00FFFFFF" Offset="0.2"/>
                                            <GradientStop Color="#60FFFFFF" Offset="0.5"/>
                                            <GradientStop Color="#00FFFFFF" Offset="0.8"/>
                                            <GradientStop Color="#00FFFFFF" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                    <Rectangle.Triggers>
                                        <EventTrigger RoutedEvent="Rectangle.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetName="ShimmerRect"
                                                        Storyboard.TargetProperty="(Canvas.Left)"
                                                        From="-160" To="900" Duration="0:0:1.8"
                                                        RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Rectangle.Triggers>
                                </Rectangle>
                                <Rectangle Canvas.Left="0" Canvas.Top="0" Width="1200" Height="5">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#45FFFFFF" Offset="0"/>
                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                            </Canvas>
                        </Border>
                    </Grid>
                </StackPanel>

                <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer"
                              Background="#141622" BorderBrush="#2C2E3E" BorderThickness="1">
                    <TextBlock x:Name="LogTextBlock" TextWrapping="Wrap"
                               Foreground="{StaticResource SecondaryColor}"
                               Padding="15" FontFamily="Consolas" FontSize="12"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ── Footer ── -->
        <StatusBar Grid.Row="4" Background="Transparent" Margin="0,15,0,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8"
                             Fill="{StaticResource SecondaryColor}" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusTextBlock" Text="Ready" Foreground="Gray" FontSize="12"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
