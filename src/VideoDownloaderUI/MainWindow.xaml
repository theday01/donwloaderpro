                                </StackPanel>
                            </Grid>
                            <Border Height="1" Background="#14162A" Margin="0,0,0,14"/>

                            <!-- v2.0 -->
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#121A12" CornerRadius="6" Padding="8,4"
                                        Margin="0,0,14,0" VerticalAlignment="Top">
                                    <TextBlock Text="v 2.0" FontSize="11" FontWeight="Bold"
                                               Foreground="#4CAF80" FontFamily="Consolas"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Major Redesign" FontSize="13" FontWeight="Bold"
                                               Foreground="White" Margin="0,0,0,5"/>
                                    <TextBlock FontSize="11" Foreground="#555" TextWrapping="Wrap"
                                               Text="+ Full WPF dark-mode UI redesign&#x0a;+ Multi-format support: MP4 · WebM · AVI · WMV · MP3 · M4A · WAV&#x0a;+ Quality presets from 144p to 4K&#x0a;+ yt-dlp integration replacing youtube-dl&#x0a;+ Animated progress bar with shimmer effect"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Footer signature ── -->
                    <Border Background="#08090F" CornerRadius="12" Padding="20,14" Margin="0,0,0,4">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="Made with " FontSize="12" Foreground="#333" VerticalAlignment="Center"/>
                                <TextBlock Text="❤" FontSize="14" Foreground="#FF4477" VerticalAlignment="Center" Margin="3,0"/>
                                <TextBlock Text=" by " FontSize="12" Foreground="#333" VerticalAlignment="Center"/>
                                <TextBlock Text="EagleShadow" FontSize="12" FontWeight="Bold"
                                           Foreground="#777" VerticalAlignment="Center"/>
                                <TextBlock Text="  ·  Powered by yt-dlp &amp; FFmpeg  ·  MIT License"
                                           FontSize="12" Foreground="#333" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ════════════════════════════════════════════════
             SETTINGS OVERLAY  (hidden by default)
             ════════════════════════════════════════════════ -->
        <Grid x:Name="SettingsOverlay" Grid.RowSpan="2" Visibility="Collapsed">

            <!-- Dim backdrop -->
            <Border Background="#CC000000" MouseDown="SettingsBackdrop_Click"/>

            <!-- Settings card slides in from right -->
            <Border x:Name="SettingsCard"
                    Background="#13152A" CornerRadius="20,0,0,20"
                    Width="420" HorizontalAlignment="Right"
                    BorderBrush="#2A2D45" BorderThickness="1,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#000000" Opacity="0.6"/>
                </Border.Effect>

                <Grid Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Settings Header -->
                    <Border x:Name="SettingsHeaderBorder" Background="#0F111A" CornerRadius="20,0,0,0" Padding="24,20">
                        <Grid>
                            <StackPanel>
                                <TextBlock x:Name="SettingsTitleText" Text="⚙  Settings" FontSize="22" FontWeight="ExtraBold"
                                           Foreground="White"/>
                                <TextBlock x:Name="SettingsSubtitleText" Text="Customize your download experience" FontSize="12"
                                           Foreground="Gray" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Style="{StaticResource IconButtonStyle}"
                                    Content="✕" FontSize="16" HorizontalAlignment="Right"
                                    VerticalAlignment="Top" Click="CloseSettings_Click"/>
                        </Grid>
                    </Border>

                    <!-- Scrollable Settings Content -->
                    <ScrollViewer x:Name="SettingsScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,8,24,8">
                        <StackPanel>

                            <!-- ── 1. DOWNLOAD LOCATION ── -->
                            <TextBlock Style="{StaticResource SettingsSectionLabel}"
                                       Text="📁  DOWNLOAD LOCATION"/>
                            <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="Save downloads to:"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="DownloadPathBox"
                                         Height="38" Padding="12,5" FontSize="12"
                                         Background="#2C2E3E" Foreground="White"
                                         BorderThickness="0" VerticalContentAlignment="Center"
                                         CaretBrush="White" FontFamily="Consolas">
                                    <TextBox.Resources>
                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="8,0,0,8"/></Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <Button Grid.Column="1" Content="Browse" Height="38" Padding="14,0"
                                        Background="#BB86FC" Foreground="Black" FontWeight="SemiBold"
                                        BorderThickness="0" Cursor="Hand" Click="BrowsePath_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="0,8,8,0" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                            <TextBlock x:Name="DownloadPathHint" FontSize="11" Foreground="#666"
                                       Text="Leave empty to save next to the application." Margin="0,0,0,4"/>

                            <!-- ── 2. APPEARANCE ── -->
                            <TextBlock Style="{StaticResource SettingsSectionLabel}" Text="🎨  APPEARANCE"/>
                            <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="Accent color theme:"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button x:Name="ThemeTeal"   Style="{StaticResource ThemeSwatchStyle}" Background="#03DAC6" ToolTip="Teal (default)" Click="Theme_Click" Tag="teal"/>
                                <Button x:Name="ThemePurple" Style="{StaticResource ThemeSwatchStyle}" Background="#BB86FC" ToolTip="Purple"         Click="Theme_Click" Tag="purple"/>
                                <Button x:Name="ThemePink"   Style="{StaticResource ThemeSwatchStyle}" Background="#FF6B9D" ToolTip="Pink"           Click="Theme_Click" Tag="pink"/>
                                <Button x:Name="ThemeBlue"   Style="{StaticResource ThemeSwatchStyle}" Background="#42A5F5" ToolTip="Blue"           Click="Theme_Click" Tag="blue"/>
                                <Button x:Name="ThemeOrange" Style="{StaticResource ThemeSwatchStyle}" Background="#FFB74D" ToolTip="Orange"         Click="Theme_Click" Tag="orange"/>
                                <Button x:Name="ThemeGreen"  Style="{StaticResource ThemeSwatchStyle}" Background="#66BB6A" ToolTip="Green"          Click="Theme_Click" Tag="green"/>
                            </StackPanel>

                            <!-- ── 3. DEFAULT PREFERENCES ── -->
                            <TextBlock Style="{StaticResource SettingsSectionLabel}" Text="🎛  DEFAULT PREFERENCES"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="Default quality:"/>
                                    <ComboBox x:Name="DefaultQualityBox" Height="36">
                                        <ComboBox.Resources>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="Background" Value="#2C2E3E"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Padding"    Value="8"/>
                                            </Style>
                                        </ComboBox.Resources>
                                        <ComboBoxItem Content="🏆 Best" Tag="best"/>
                                        <ComboBoxItem Content="4K — 2160p" Tag="2160"/>
                                        <ComboBoxItem Content="FHD — 1080p" Tag="1080"/>
                                        <ComboBoxItem Content="HD — 720p"   Tag="720"/>
                                        <ComboBoxItem Content="SD — 480p"   Tag="480"/>
                                        <ComboBoxItem Content="Low — 360p"  Tag="360"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="Default format:"/>
                                    <ComboBox x:Name="DefaultFormatBox" Height="36">
                                        <ComboBox.Resources>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="Background" Value="#2C2E3E"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Padding"    Value="8"/>
                                            </Style>
                                        </ComboBox.Resources>
                                        <ComboBoxItem Content="MP4"    Tag="mp4"/>
                                        <ComboBoxItem Content="WebM"   Tag="webm"/>
                                        <ComboBoxItem Content="AVI"    Tag="avi"/>
                                        <ComboBoxItem Content="WMV"    Tag="wmv"/>
                                        <ComboBoxItem Content="MP3 🎵" Tag="mp3"/>
                                        <ComboBoxItem Content="M4A 🎵" Tag="m4a"/>
                                        <ComboBoxItem Content="WAV 🎵" Tag="wav"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!-- ── 4. BEHAVIOR ── -->
                            <TextBlock Style="{StaticResource SettingsSectionLabel}" Text="⚡  BEHAVIOR"/>
                            <Border x:Name="BehaviorCard" Background="#1A1C2E" CornerRadius="12" Padding="16,12" Margin="0,0,0,8">
                                <StackPanel>
                                    <CheckBox x:Name="AutoOpenFolderCheck"   Style="{StaticResource ToggleCheckStyle}" Content="Open download folder when done"          Margin="0,0,0,14"/>
                                    <CheckBox x:Name="ShowNotificationCheck" Style="{StaticResource ToggleCheckStyle}" Content="Show notification on completion"         Margin="0,0,0,14"/>
                                    <CheckBox x:Name="ClearLogCheck"         Style="{StaticResource ToggleCheckStyle}" Content="Clear log before each download"          Margin="0,0,0,14"/>
                                    <CheckBox x:Name="SkipDuplicateCheck"    Style="{StaticResource ToggleCheckStyle}" Content="Skip duplicate file check (not recommended)" Margin="0,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- ── 5. SYSTEM THEME ── -->
                            <TextBlock Style="{StaticResource SettingsSectionLabel}" Text="🌗  SYSTEM THEME"/>
                            <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="Choose the interface appearance mode:"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="DarkThemeCard" CornerRadius="12" Padding="14,16" Cursor="Hand"
                                        Background="#1A1C2E" BorderThickness="2" BorderBrush="#03DAC6"
                                        MouseDown="DarkThemeCard_Click">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="🌙" FontSize="28" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Dark Mode" FontSize="13" FontWeight="Bold"
                                                   Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,2"/>
                                        <TextBlock Text="Easy on the eyes" FontSize="11"
                                                   Foreground="#888" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="LightThemeCard" Grid.Column="2" CornerRadius="12" Padding="14,16" Cursor="Hand"
                                        Background="#2C2E3E" BorderThickness="2" BorderBrush="Transparent"
                                        MouseDown="LightThemeCard_Click">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="☀️" FontSize="28" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Light Mode" FontSize="13" FontWeight="Bold"
                                                   Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,2"/>
                                        <TextBlock Text="Bright &amp; clean" FontSize="11"
                                                   Foreground="#888" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <TextBlock x:Name="ThemeRestartHint" FontSize="11" Foreground="#888" Margin="0,2,0,0"
                                       Text="ℹ Changes will be applied after saving." TextWrapping="Wrap"/>
                            <Border Height="20"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Save & Reset footer -->
                    <Border x:Name="SettingsFooterBorder" Grid.Row="2" Background="#0F111A" CornerRadius="0,0,0,20" Padding="24,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ResetButton" Content="↺ Reset defaults" Cursor="Hand"
                                    Background="Transparent" Foreground="#666"
                                    BorderThickness="0" FontSize="12" VerticalAlignment="Center"
                                    Click="ResetSettings_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock Text="{TemplateBinding Content}"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   FontSize="{TemplateBinding FontSize}"
                                                   TextDecorations="Underline" Cursor="Hand"/>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Grid.Column="2" Content="✔  Save Settings"
                                    Width="150" Height="42" Padding="0"
                                    Style="{StaticResource SettingsSaveStyle}"
                                    Click="SaveSettings_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
