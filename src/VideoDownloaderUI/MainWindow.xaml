<Window x:Class="VideoDownloaderUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VideoDownloaderUI"
        mc:Ignorable="d"
        Title="Jules Pro Video Downloader" Height="600" Width="900"
        Background="#0F111A" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryColor"   Color="#BB86FC"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#03DAC6"/>
        <SolidColorBrush x:Key="CardColor"      Color="#1E202E"/>

        <!-- Button -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource SecondaryColor}"/>
            <Setter Property="Foreground"      Value="Black"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.8"/></Trigger>
                <Trigger Property="IsEnabled"   Value="False"><Setter Property="Background" Value="Gray"/></Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"               Value="#2C2E3E"/>
            <Setter Property="Foreground"               Value="White"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="Padding"                  Value="10,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="#2C2E3E" CornerRadius="8" Padding="5">
                            <Grid>
                                <ToggleButton Background="Transparent" BorderThickness="0" Focusable="false"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                          RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press"/>
                                <ContentPresenter IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  Margin="3,3,23,3" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                <Path Fill="White" HorizontalAlignment="Right"
                                      VerticalAlignment="Center" Margin="0,0,10,0"
                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                                <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                    <Border Background="#2C2E3E" BorderThickness="1" BorderBrush="#3F4154"
                                            CornerRadius="8" MinWidth="{TemplateBinding ActualWidth}"
                                            MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Margin="0,0,0,30">
            <TextBlock Text="Video Downloader Pro" FontSize="36" FontWeight="ExtraBold"
                       Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center"/>
            <TextBlock Text="Fast &amp; High Quality Downloads" FontSize="14" Foreground="Gray"
                       HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Input card -->
        <Border Grid.Row="1" Background="{StaticResource CardColor}"
                CornerRadius="15" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <Grid Margin="0,0,0,15">
                    <TextBox x:Name="UrlTextBox" Height="45" Padding="15,5" FontSize="15"
                             Background="#2C2E3E" Foreground="White" BorderThickness="0"
                             VerticalContentAlignment="Center" CaretBrush="White">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <TextBlock IsHitTestVisible="False" Text="أدخل رابط الفيديو هنا..."
                               VerticalAlignment="Center" HorizontalAlignment="Left"
                               Margin="20,0,0,0" Foreground="Gray" FontSize="15">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=UrlTextBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Quality" Foreground="Gray" FontSize="12" Margin="5,0,0,5"/>
                        <ComboBox x:Name="QualityComboBox" Height="40" SelectedIndex="0">
                            <ComboBox.Resources>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Background" Value="#2C2E3E"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Padding"    Value="10"/>
                                </Style>
                            </ComboBox.Resources>
                            <ComboBoxItem Content="Best Quality" Tag="best"/>
                            <ComboBoxItem Content="1080p"        Tag="1080"/>
                            <ComboBoxItem Content="720p"         Tag="720"/>
                            <ComboBoxItem Content="480p"         Tag="480"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,10,0">
                        <TextBlock Text="Format" Foreground="Gray" FontSize="12" Margin="5,0,0,5"/>
                        <ComboBox x:Name="FormatComboBox" Height="40" SelectedIndex="0">
                            <ComboBox.Resources>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Background" Value="#2C2E3E"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Padding"    Value="10"/>
                                </Style>
                            </ComboBox.Resources>
                            <ComboBoxItem Content="MP4"  Tag="mp4"/>
                            <ComboBoxItem Content="WebM" Tag="webm"/>
                        </ComboBox>
                    </StackPanel>

                    <Button x:Name="DownloadButton" Grid.Column="2"
                            Content="DOWNLOAD NOW" Width="180" Height="40"
                            VerticalAlignment="Bottom" Padding="20,10"
                            Style="{StaticResource ModernButtonStyle}"
                            Click="DownloadButton_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Progress + Log card -->
        <Border Grid.Row="2" Background="{StaticResource CardColor}" CornerRadius="15" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Progress section -->
                <StackPanel Margin="0,0,0,15">
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Download Progress" Foreground="Gray" FontSize="12"/>
                        <TextBlock x:Name="PercentageTextBlock" Text="0%"
                                   Foreground="{StaticResource PrimaryColor}"
                                   HorizontalAlignment="Right" FontSize="12" FontWeight="Bold"/>
                    </Grid>

                    <!--
                        Custom progress bar — a Grid with a dark background Border (track)
                        and a colored Border (fill) whose Width we set from code-behind.
                        No WPF ProgressBar template magic = guaranteed to work.
                    -->
                    <Grid x:Name="ProgressTrack" Height="14"
                          SizeChanged="ProgressTrack_SizeChanged">
                        <!-- Track background -->
                        <Border CornerRadius="7" Background="#1C1D2B"/>

                        <!-- Animated fill — Width is set from code-behind -->
                        <Border x:Name="ProgressFill"
                                HorizontalAlignment="Left"
                                CornerRadius="7"
                                Width="0"
                                ClipToBounds="True">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1A6B00" Offset="0.0"/>
                                    <GradientStop Color="#39FF14" Offset="0.5"/>
                                    <GradientStop Color="#1DB300" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <!-- Shimmer canvas clipped inside fill -->
                            <Canvas IsHitTestVisible="False" ClipToBounds="True">

                                <!-- Shimmer sweep -->
                                <Rectangle x:Name="ShimmerRect"
                                           Width="160" Height="40"
                                           Canvas.Left="-160" Canvas.Top="-13">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00FFFFFF" Offset="0.0"/>
                                            <GradientStop Color="#00FFFFFF" Offset="0.2"/>
                                            <GradientStop Color="#60FFFFFF" Offset="0.5"/>
                                            <GradientStop Color="#00FFFFFF" Offset="0.8"/>
                                            <GradientStop Color="#00FFFFFF" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                    <Rectangle.Triggers>
                                        <EventTrigger RoutedEvent="Rectangle.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="ShimmerRect"
                                                        Storyboard.TargetProperty="(Canvas.Left)"
                                                        From="-160" To="900"
                                                        Duration="0:0:1.8"
                                                        RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Rectangle.Triggers>
                                </Rectangle>

                                <!-- Glass top shine -->
                                <Rectangle Canvas.Left="0" Canvas.Top="0" Width="1200" Height="5">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#45FFFFFF" Offset="0"/>
                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                            </Canvas>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- Log -->
                <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer"
                              Background="#141622" BorderBrush="#2C2E3E" BorderThickness="1">
                    <TextBlock x:Name="LogTextBlock" TextWrapping="Wrap"
                               Foreground="{StaticResource SecondaryColor}"
                               Padding="15" FontFamily="Consolas" FontSize="12"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Footer -->
        <StatusBar Grid.Row="3" Background="Transparent" Margin="0,15,0,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource SecondaryColor}" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusTextBlock" Text="Ready" Foreground="Gray" FontSize="12"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
