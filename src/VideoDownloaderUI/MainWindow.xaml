                                </Border>
                                <Border x:Name="LightThemeCard" Grid.Column="2" CornerRadius="12" Padding="14,16" Cursor="Hand"
                                        Background="#2C2E3E" BorderThickness="2" BorderBrush="Transparent"
                                        MouseDown="LightThemeCard_Click">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="&#x2600;&#xFE0F;" FontSize="28" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Light Mode" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,2"/>
                                        <TextBlock Text="Bright &amp; clean" FontSize="11" Foreground="#888" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <TextBlock x:Name="ThemeRestartHint" FontSize="11" Foreground="#888" Margin="0,2,0,0"
                                       Text="&#x2139; Changes will be applied after saving." TextWrapping="Wrap"/>
                            <Border Height="20"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Border x:Name="SettingsFooterBorder" Grid.Row="2" Background="#0F111A" CornerRadius="0,0,0,20" Padding="24,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ResetButton" Content="&#x21BA; Reset defaults" Cursor="Hand"
                                    Background="Transparent" Foreground="#666"
                                    BorderThickness="0" FontSize="12" VerticalAlignment="Center"
                                    Click="ResetSettings_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"
                                                   FontSize="{TemplateBinding FontSize}" TextDecorations="Underline" Cursor="Hand"/>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Grid.Column="2" Content="&#x2714;  Save Settings" Width="150" Height="42" Padding="0"
                                    Style="{StaticResource SettingsSaveStyle}" Click="SaveSettings_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
