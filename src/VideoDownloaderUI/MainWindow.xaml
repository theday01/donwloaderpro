                                                    <StackPanel Grid.Column="1">
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                            <Border Background="#1E0814" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                                                <TextBlock Text="THEMING" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="#FF6B9D"/>
                                                            </Border>
                                                            <TextBlock Text="{DynamicResource v2_1_Accent_Title}" FontSize="12" FontWeight="SemiBold" Foreground="#DDDDDD" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{DynamicResource v2_1_Accent_Desc}" FontSize="11" Foreground="#555" TextWrapping="Wrap" LineHeight="16"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Height="1" Margin="24,0" Background="#14162A"/>

                            <!-- v 2.0 -->
                            <Border Padding="24,22,24,20" Background="Transparent">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="64"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#121A12" CornerRadius="8" Padding="0,6"
                                            HorizontalAlignment="Center" Width="52" VerticalAlignment="Top" Margin="0,2,0,0">
                                        <TextBlock Text="v 2.0" FontFamily="Consolas" FontSize="12"
                                                   FontWeight="Bold" Foreground="#4CAF80" HorizontalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                    <TextBlock Text="{DynamicResource v2_0_Title}" FontSize="15" FontWeight="Bold"
                                                               Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                                    <Border Background="#121A12" CornerRadius="10" Padding="8,3"
                                                            Margin="10,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="STABLE" FontFamily="Consolas" FontSize="9"
                                                                   FontWeight="Bold" Foreground="#4CAF80"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{DynamicResource v2_0_Date}" FontFamily="Consolas" FontSize="10" Foreground="#333"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="#12101C" CornerRadius="8" Padding="10,5" VerticalAlignment="Top">
                                                <TextBlock Text="{DynamicResource v2_0_ChangesCount}" FontFamily="Consolas" FontSize="11" Foreground="#444"/>
                                            </Border>
                                        </Grid>
                                        <StackPanel>
                                            <Border Margin="0,0,0,5" CornerRadius="7" Padding="10,8" Background="#0A0B0F" BorderThickness="1" BorderBrush="#181A22">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="#1A0D2E" CornerRadius="4" Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center"><TextBlock Text="UI" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="#BB86FC"/></Border>
                                                    <TextBlock Text="{DynamicResource v2_0_UI_Desc}" FontSize="12" Foreground="#888" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Margin="0,0,0,5" CornerRadius="7" Padding="10,8" Background="#0A0B0F" BorderThickness="1" BorderBrush="#181A22">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="#141B2A" CornerRadius="4" Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center"><TextBlock Text="FORMAT" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="#42A5F5"/></Border>
                                                    <TextBlock Text="{DynamicResource v2_0_Format_Desc}" FontSize="12" Foreground="#888" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Margin="0,0,0,5" CornerRadius="7" Padding="10,8" Background="#0A0B0F" BorderThickness="1" BorderBrush="#181A22">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="#1A1800" CornerRadius="4" Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center"><TextBlock Text="QUALITY" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="#FFB74D"/></Border>
                                                    <TextBlock Text="{DynamicResource v2_0_Quality_Desc}" FontSize="12" Foreground="#888" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Margin="0,0,0,5" CornerRadius="7" Padding="10,8" Background="#0A0B0F" BorderThickness="1" BorderBrush="#181A22">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="#0B1C0B" CornerRadius="4" Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center"><TextBlock Text="ENGINE" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="#4CAF50"/></Border>
                                                    <TextBlock Text="{DynamicResource v2_0_Engine_Desc}" FontSize="12" Foreground="#888" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <Border CornerRadius="7" Padding="10,8" Background="#0A0B0F" BorderThickness="1" BorderBrush="#181A22">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="#1E0814" CornerRadius="4" Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center"><TextBlock Text="ANIM" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="#FF6B9D"/></Border>
                                                    <TextBlock Text="{DynamicResource v2_0_Anim_Desc}" FontSize="12" Foreground="#888" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Height="1" Margin="24,0" Background="#14162A"/>

                            <!-- v 1.0 -->
                            <Border Padding="24,20,24,20" Background="Transparent">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="64"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#141414" CornerRadius="8" Padding="0,6"
                                            HorizontalAlignment="Center" Width="52" VerticalAlignment="Top" Margin="0,2,0,0">
                                        <TextBlock Text="v 1.0" FontFamily="Consolas" FontSize="12"
                                                   FontWeight="Bold" Foreground="#444" HorizontalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                            <TextBlock Text="{DynamicResource v1_0_Title}" FontSize="14" FontWeight="Bold"
                                                       Foreground="#555" VerticalAlignment="Center"/>
                                            <Border Background="#1A1A1A" CornerRadius="10" Padding="8,3"
                                                    Margin="10,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="LEGACY" FontFamily="Consolas" FontSize="9"
                                                           FontWeight="Bold" Foreground="#3A3A3A"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{DynamicResource v1_0_Date}" FontFamily="Consolas"
                                                   FontSize="10" Foreground="#2A2A2A" Margin="0,0,0,10"/>
                                        <TextBlock Text="{DynamicResource v1_0_Desc}" FontSize="11" Foreground="#3A3A3A" TextWrapping="Wrap" LineHeight="18"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </Border>

                    <!-- Footer -->
                    <Border Background="#08090F" CornerRadius="12" Padding="20,14" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{DynamicResource MadeWith}" FontSize="12" Foreground="#333" VerticalAlignment="Center"/>
                            <TextBlock Text="&#x2764;" FontSize="14" Foreground="#FF4477" VerticalAlignment="Center" Margin="3,0"/>
                            <TextBlock Text="{DynamicResource ByLabel}" FontSize="12" Foreground="#333" VerticalAlignment="Center"/>
                            <TextBlock Text="EagleShadow" FontSize="12" FontWeight="Bold" Foreground="#777" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource AllRightsReserved}" FontSize="12" Foreground="#333" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- SETTINGS OVERLAY -->
        <Grid x:Name="SettingsOverlay" Grid.RowSpan="2" Visibility="Collapsed">
            <Border Background="#CC000000" MouseDown="SettingsBackdrop_Click"/>
            <Border x:Name="SettingsCard" Background="#13152A" CornerRadius="20,0,0,20"
                    Width="420" HorizontalAlignment="Right" BorderBrush="#2A2D45" BorderThickness="1,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#000000" Opacity="0.6"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border x:Name="SettingsHeaderBorder" Background="#0F111A" CornerRadius="20,0,0,0" Padding="24,20">
                        <Grid>
                            <StackPanel>
                                <TextBlock x:Name="SettingsTitleText" Text="{DynamicResource SettingsTitle}" FontSize="22" FontWeight="ExtraBold" Foreground="White"/>
                                <TextBlock x:Name="SettingsSubtitleText" Text="{DynamicResource SettingsSubtitle}" FontSize="12" Foreground="Gray" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Style="{StaticResource IconButtonStyle}" Content="&#x2715;" FontSize="16"
                                    HorizontalAlignment="Right" VerticalAlignment="Top" Click="CloseSettings_Click"/>
                        </Grid>
                    </Border>

                    <ScrollViewer x:Name="SettingsScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,8,24,8">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SettingsSectionLabel}" Text="{DynamicResource DownloadLocationLabel}"/>
                            <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="{DynamicResource SaveToLabel}"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="DownloadPathBox" Height="38" Padding="12,5" FontSize="12"
                                         Background="#2C2E3E" Foreground="White" BorderThickness="0"
                                         VerticalContentAlignment="Center" CaretBrush="White" FontFamily="Consolas">
                                    <TextBox.Resources>
                                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="8,0,0,8"/></Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <Button Grid.Column="1" Content="{DynamicResource BrowseButtonText}" Height="38" Padding="14,0"
                                        Background="#BB86FC" Foreground="Black" FontWeight="SemiBold"
                                        BorderThickness="0" Cursor="Hand" Click="BrowsePath_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="0,8,8,0" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                            <TextBlock x:Name="DownloadPathHint" FontSize="11" Foreground="#666"
                                       Text="{DynamicResource DownloadPathHintText}" Margin="0,0,0,4"/>

                            <TextBlock Style="{StaticResource SettingsSectionLabel}" Text="{DynamicResource AppearanceLabel}"/>
                            <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="{DynamicResource AccentThemeLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button x:Name="ThemeTeal"   Style="{StaticResource ThemeSwatchStyle}" Background="#03DAC6" ToolTip="Teal" Click="Theme_Click" Tag="teal"/>
                                <Button x:Name="ThemePurple" Style="{StaticResource ThemeSwatchStyle}" Background="#BB86FC" ToolTip="Purple"         Click="Theme_Click" Tag="purple"/>
                                <Button x:Name="ThemePink"   Style="{StaticResource ThemeSwatchStyle}" Background="#FF6B9D" ToolTip="Pink"           Click="Theme_Click" Tag="pink"/>
                                <Button x:Name="ThemeBlue"   Style="{StaticResource ThemeSwatchStyle}" Background="#42A5F5" ToolTip="Blue"           Click="Theme_Click" Tag="blue"/>
                                <Button x:Name="ThemeOrange" Style="{StaticResource ThemeSwatchStyle}" Background="#FFB74D" ToolTip="Orange"         Click="Theme_Click" Tag="orange"/>
                                <Button x:Name="ThemeGreen"  Style="{StaticResource ThemeSwatchStyle}" Background="#66BB6A" ToolTip="Green"          Click="Theme_Click" Tag="green"/>
                            </StackPanel>

                            <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="{DynamicResource LanguageLabel}"/>
                            <ComboBox x:Name="LanguageComboBox" Height="36" Margin="0,0,0,12">
                                <ComboBox.Resources>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="#2C2E3E"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Padding"    Value="8"/>
                                    </Style>
                                </ComboBox.Resources>
                                <ComboBoxItem Content="English" Tag="en"/>
                                <ComboBoxItem Content="العربية (Arabic)" Tag="ar"/>
                            </ComboBox>

                            <TextBlock Style="{StaticResource SettingsSectionLabel}" Text="{DynamicResource DefaultPrefsLabel}"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="{DynamicResource DefaultQualityLabel}"/>
                                    <ComboBox x:Name="DefaultQualityBox" Height="36">
                                        <ComboBox.Resources>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="Background" Value="#2C2E3E"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Padding"    Value="8"/>
                                            </Style>
                                        </ComboBox.Resources>
                                        <ComboBoxItem Content="&#x1F3C6; Best" Tag="best"/>
                                        <ComboBoxItem Content="4K — 2160p" Tag="2160"/>
                                        <ComboBoxItem Content="FHD — 1080p" Tag="1080"/>
                                        <ComboBoxItem Content="HD — 720p"   Tag="720"/>
                                        <ComboBoxItem Content="SD — 480p"   Tag="480"/>
                                        <ComboBoxItem Content="Low — 360p"  Tag="360"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="{DynamicResource DefaultFormatLabel}"/>
                                    <ComboBox x:Name="DefaultFormatBox" Height="36">
                                        <ComboBox.Resources>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="Background" Value="#2C2E3E"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Padding"    Value="8"/>
                                            </Style>
                                        </ComboBox.Resources>
                                        <ComboBoxItem Content="MP4"    Tag="mp4"/>
                                        <ComboBoxItem Content="WebM"   Tag="webm"/>
                                        <ComboBoxItem Content="AVI"    Tag="avi"/>
                                        <ComboBoxItem Content="WMV"    Tag="wmv"/>
                                        <ComboBoxItem Content="MP3 &#x1F3B5;" Tag="mp3"/>
                                        <ComboBoxItem Content="M4A &#x1F3B5;" Tag="m4a"/>
                                        <ComboBoxItem Content="WAV &#x1F3B5;" Tag="wav"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <TextBlock Style="{StaticResource SettingsSectionLabel}" Text="{DynamicResource BehaviorLabel}"/>
                            <Border x:Name="BehaviorCard" Background="#1A1C2E" CornerRadius="12" Padding="16,12" Margin="0,0,0,8">
                                <StackPanel>
                                    <CheckBox x:Name="AutoOpenFolderCheck"   Style="{StaticResource ToggleCheckStyle}" Content="{DynamicResource OpenFolderCheck}"             Margin="0,0,0,14"/>
                                    <CheckBox x:Name="ShowNotificationCheck" Style="{StaticResource ToggleCheckStyle}" Content="{DynamicResource NotificationCheck}"            Margin="0,0,0,14"/>
                                    <CheckBox x:Name="ClearLogCheck"         Style="{StaticResource ToggleCheckStyle}" Content="{DynamicResource ClearLogCheck}"             Margin="0,0,0,14"/>
                                    <CheckBox x:Name="SkipDuplicateCheck"    Style="{StaticResource ToggleCheckStyle}" Content="{DynamicResource SkipDuplicateCheck}" Margin="0,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Style="{StaticResource SettingsSectionLabel}" Text="{DynamicResource SystemThemeLabel}"/>
                            <TextBlock Style="{StaticResource SettingsFieldLabel}" Text="{DynamicResource SystemThemeSubtitle}"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="DarkThemeCard" CornerRadius="12" Padding="14,16" Cursor="Hand"
                                        Background="#1A1C2E" BorderThickness="2" BorderBrush="#03DAC6"
                                        MouseDown="DarkThemeCard_Click">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="&#x1F319;" FontSize="28" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource DarkMode}" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,2"/>
                                        <TextBlock Text="{DynamicResource ModeEyes}" FontSize="11" Foreground="#888" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="LightThemeCard" Grid.Column="2" CornerRadius="12" Padding="14,16" Cursor="Hand"
                                        Background="#2C2E3E" BorderThickness="2" BorderBrush="Transparent"
                                        MouseDown="LightThemeCard_Click">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="&#x2600;&#xFE0F;" FontSize="28" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource LightMode}" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,6,0,2"/>
                                        <TextBlock Text="{DynamicResource ModeBright}" FontSize="11" Foreground="#888" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <TextBlock x:Name="ThemeRestartHint" FontSize="11" Foreground="#888" Margin="0,2,0,0"
                                       Text="{DynamicResource ThemeRestartHintText}" TextWrapping="Wrap"/>
                            <Border Height="20"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Border x:Name="SettingsFooterBorder" Grid.Row="2" Background="#0F111A" CornerRadius="0,0,0,20" Padding="24,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ResetButton" Content="{DynamicResource ResetDefaults}" Cursor="Hand"
                                    Background="Transparent" Foreground="#666"
                                    BorderThickness="0" FontSize="12" VerticalAlignment="Center"
                                    Click="ResetSettings_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"
                                                   FontSize="{TemplateBinding FontSize}" TextDecorations="Underline" Cursor="Hand"/>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Grid.Column="2" Content="{DynamicResource SaveSettings}" Width="150" Height="42" Padding="0"
                                    Style="{StaticResource SettingsSaveStyle}" Click="SaveSettings_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
